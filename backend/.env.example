PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://127.0.0.1:27017/tekron
FRONTEND_URL=http://localhost:3000

JWT_ACCESS_SECRET=replace_with_long_random_access_secret_at_least_32_chars
JWT_REFRESH_SECRET=replace_with_long_random_refresh_secret_at_least_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

REDIS_URL=redis://localhost:6379
# Set to false if Redis is not installed (caching disabled, no connection attempts)
REDIS_ENABLED=true

# Images are stored locally in backend/uploads/ (no Cloudinary required)

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

SEED_ADMIN_NAME=Tekron Admin
SEED_ADMIN_EMAIL=admin@tekron.com
SEED_ADMIN_PASSWORD=Admin@12345
